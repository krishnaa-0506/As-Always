{
  "name": "asalways-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "seed": "node scripts/seed-templates-themes.js",
    "download-audio": "node scripts/download-audio.mjs",
    "dev": "node scripts/dev.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:init": "npx prisma generate && npx prisma db push",
    "deploy": "npm run db:init && npm run build",
    "generate-embeddings": "node scripts/generate-embeddings.js",
    "setup-qdrant-local": "docker run -p 6333:6333 qdrant/qdrant",
    "setup-qdrant-cloud": "node scripts/setup-qdrant-cloud.js",
    "security-audit": "node scripts/security-audit.js",
    "security-fix": "node scripts/security-fixes.js",
    "download-assets": "node scripts/download-assets.js",
    "verify-assets": "node scripts/verify-assets.js",
    "optimize-assets": "node scripts/optimize-assets.js",
    "prepare-assets": "npm run download-assets && npm run optimize-assets && npm run verify-assets",
    "download-all": "node scripts/download-all-assets.js"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.17",
    "@heroicons/react": "^2.2.0",
    "@prisma/client": "^5.6.0",
    "@qdrant/js-client-rest": "^1.7.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@xenova/transformers": "^2.6.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.2.1",
    "framer-motion": "^10.16.0",
    "glob": "^11.0.3",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.18.0",
    "multer": "^2.0.2",
    "next": "^14.2.24",
    "nodemailer": "^6.9.7",
    "pino": "^9.9.0",
    "pino-pretty": "^13.1.1",
    "prisma": "^5.6.0",
    "react": "^18",
    "react-dom": "^18",
    "react-dropzone": "^14.2.3",
    "readable-stream": "^4.7.0",
    "sharp": "^0.34.3",
    "tailwindcss": "^3.3.0",
    "typescript": "^5",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^6.4.17",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.0.0",
    "postcss": "^8"
  }
